EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-status
EXPO_PUBLIC_APP_ENV=development
# Base URL of the local Express backend (npm run api, default port 3001).
# On a physical iPhone, 127.0.0.1 points at the phone itself -- replace the
# host with your development computer's LAN address, same as
# EXPO_PUBLIC_SUPABASE_URL above. See docs/LOCAL_DEVELOPMENT.md.
EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:3001
