{
  "expo": {
    "name": "Litmo",
    "slug": "litmo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "litmo",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Litmo to use Face ID to protect your private consent and session information."
        }
      ],
      "./plugins/withIOSXcode27Fixes.cjs",
      "./plugins/withoutPushEntitlement.cjs"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.litmo.app",
      "appleTeamId": "FHZSE6U4R5"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F1E8"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01be958b-59d4-4782-8ccd-1e15a15bc6ba"
      }
    }
  }
}
