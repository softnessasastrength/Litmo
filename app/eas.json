{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "maximum",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "app_store",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "preview_simulator": {
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "maximum",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "device_beta": {
      "developmentClient": false,
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "maximum",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "app_store",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "production_maximum_internal": {
      "autoIncrement": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "maximum",
        "EXPO_PUBLIC_LITMO_PLATFORM": "ios"
      }
    },
    "maximum_linux_ci": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_LITMO_BUILD_MODE": "maximum",
        "EXPO_PUBLIC_LITMO_PLATFORM": "linux"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
