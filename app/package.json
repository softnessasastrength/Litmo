{
  "name": "litmo-app",
  "version": "0.1.0",
  "private": true,
  "license": "MPL-2.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test lib/*.test.ts context/*.test.ts services/*.test.ts data/*.test.ts",
    "build": "expo export --platform ios --output-dir dist",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@litmo/domain": "*",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@supabase/supabase-js": "^2.110.2",
    "expo": "~55.0.27",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.15",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.15",
    "expo-notifications": "~55.0.24",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-status-bar": "~55.0.0",
    "litmo-age-range": "file:modules/litmo-age-range",
    "litmo-passkeys": "file:modules/litmo-passkeys",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "prettier": "^3.9.5",
    "typescript": "~5.9.2"
  }
}
